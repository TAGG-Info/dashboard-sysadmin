# ════════════════════════════════════════
# ║         APPLICATION                  ║
# ════════════════════════════════════════
NEXT_PUBLIC_APP_NAME="SysAdmin Dashboard"
NODE_ENV=production

# ════════════════════════════════════════
# ║         TLS / CERTIFICATS            ║
# ════════════════════════════════════════
# Accepter les certificats auto-signés (vCenter, Proxmox, Veeam, GLPI...).
# Acceptable en réseau interne de confiance.
ALLOW_SELF_SIGNED_CERTS=true

# ════════════════════════════════════════
# ║         AUTHENTIFICATION             ║
# ════════════════════════════════════════
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://dashboard.internal.example.com
# Salt pour le chiffrement AES-256-GCM des configs sensibles (config.json).
# OBLIGATOIRE en production (le serveur refuse de démarrer sans).
# Générer avec : openssl rand -base64 16
CRYPTO_SALT=generate-with-openssl-rand-base64-16
# LDAP / Active Directory
LDAP_URL=ldaps://dc.internal.example.com:636
LDAP_BASE_DN=DC=internal,DC=example,DC=com
LDAP_BIND_DN=CN=svc-dashboard,OU=ServiceAccounts,DC=internal,DC=example,DC=com
LDAP_BIND_PASSWORD=your-bind-password
LDAP_USER_SEARCH_FILTER=(sAMAccountName={{username}})
LDAP_ADMIN_GROUP=Dashboard-Admins
# TLS LDAP : mettre à false si ton AD/LDAP utilise un cert auto-signé.
# Par défaut strict (true). Ne désactiver qu'en réseau interne de confiance.
# LDAP_TLS_REJECT_UNAUTHORIZED=false
# Admin local (fallback si AD indisponible)
LOCAL_ADMIN_USERNAME=admin
# IMPORTANT : Docker Compose interprete les $ dans les valeurs du .env.
# Le hash bcrypt contient des $ ($2b$10$...) qui sont supprimes par Docker.
# => Stocker le hash encode en base64 (le code le decode automatiquement).
# Generer avec :
#   node -e "const b=require('bcryptjs'); console.log(Buffer.from(b.hashSync('MOT_DE_PASSE',10)).toString('base64'))"
# Sans Docker (dev local), le hash brut $2b$10$... fonctionne aussi.
LOCAL_ADMIN_PASSWORD_HASH=your-base64-encoded-bcrypt-hash

# ════════════════════════════════════════
# ║         SOURCES — LIENS EXTERNES     ║
# ════════════════════════════════════════
# URLs affichées dans le frontend pour ouvrir les outils dans un nouvel onglet.
# Les credentials API se configurent dans Settings > Sources.
NEXT_PUBLIC_PRTG_URL=https://prtg.internal.example.com
NEXT_PUBLIC_VCENTER_URL=https://vcenter.internal.example.com/ui
NEXT_PUBLIC_PROXMOX_URL=https://proxmox.internal.example.com:8006
NEXT_PUBLIC_VEEAM_URL=https://veeam.internal.example.com:9419
NEXT_PUBLIC_GLPI_URL=https://glpi.internal.example.com
NEXT_PUBLIC_ST_URL=https://securetransport.internal.example.com:8444

# ════════════════════════════════════════
# ║         CACHE & REFRESH              ║
# ════════════════════════════════════════
# Password Redis — utilisé par docker-compose pour --requirepass.
# IMPORTANT : REDIS_URL doit inclure le password si défini.
# Générer avec : openssl rand -base64 32
REDIS_PASSWORD=changeme-to-strong-password
REDIS_URL=redis://:changeme-to-strong-password@redis:6379
CACHE_TTL_PRTG=30
CACHE_TTL_VCENTER=60
CACHE_TTL_PROXMOX=60
CACHE_TTL_VEEAM=120
CACHE_TTL_GLPI=60
CACHE_TTL_ST=120
NEXT_PUBLIC_REFRESH_PRTG=30000
NEXT_PUBLIC_REFRESH_INFRA=60000
NEXT_PUBLIC_REFRESH_VEEAM=120000
NEXT_PUBLIC_REFRESH_TICKETS=60000
NEXT_PUBLIC_REFRESH_TRANSFERS=120000
# Necessaire derriere un reverse proxy (Caddy, nginx...) pour que NextAuth
# fasse confiance au header Host forwarde.
AUTH_TRUST_HOST=true
